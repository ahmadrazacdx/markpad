{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MarkPad",
  "version": "0.1.1",
  "identifier": "com.markpad.desktop",
  "build": {
    "beforeBuildCommand": "pnpm run build:desktop:web",
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:19551",
    "frontendDist": "../dist/public"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "MarkPad",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Ahmad Raza",
    "homepage": "https://github.com/ahmadrazacdx/markpad",
    "copyright": "Copyright (c) 2026 Ahmad Raza",
    "license": "MIT",
    "licenseFile": "../../../../LICENSE",
    "category": "Productivity",
    "shortDescription": "Local-first Markdown editor with live PDF preview.",
    "longDescription": "MarkPad is a desktop writing app for Markdown-first workflows with project management, file history, and real-time PDF preview powered by pandoc and typst.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "resources": ["resources/backend", "resources/runtime", "resources/bin"],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/nsis-header.bmp",
        "sidebarImage": "icons/nsis-sidebar.bmp",
        "startMenuFolder": "MarkPad",
        "installMode": "currentUser",
        "languages": ["English"]
      }
    }
  }
}
